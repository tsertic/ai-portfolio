# Copy this file to .env and fill in your API key(s)
# .env is in .gitignore — never commit your real keys!

# Which AI provider to use: claude | openai | gemini
AI_PROVIDER=claude

# Optionally override the model (leave empty to use defaults)
# Defaults: claude-opus-4-6 | gpt-4o | gemini-2.0-flash
AI_MODEL=

# Anthropic Claude API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API key (https://platform.openai.com)
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini API key (https://aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here
